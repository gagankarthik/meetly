# =========================================================
# Meetly — BUILD-TIME environment template (developer only)
# Copy to `.env.local` and fill in. These values get BAKED into the .exe
# at build time so end users never see this file.
# End users only need to download the installer and sign up.
# =========================================================

# ---- Deepgram (streaming transcription) ----
# Shipped users will use this key by default. They can override with their own
# in Settings (stored in their OS keychain). Note: anyone who downloads the
# installer can extract this key from app.asar. Set billing alarms.
DEEPGRAM_API_KEY=

# ---- OpenAI (live assist + summaries + vision) ----
# Same caveat as Deepgram — extractable from the installer. Set spend caps.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# ---- AWS region (all services in same region) ----
AWS_REGION=us-east-1

# ---- AWS Cognito (User Pool + Identity Pool — created by Terraform) ----
# Run `terraform output env_template` in /infra to get these.
# These IDs are public (visible in network traffic) — safe to ship.
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_IDENTITY_POOL_ID=

# ---- DynamoDB ----
DYNAMODB_TABLE=Meetly

# ---- Development only (never read by packaged builds) ----
# Bypass content-protection so you can screenshot for design QA.
VITE_DEV_DISABLE_STEALTH=false
# Bypass Cognito sign-in entirely (only honored in `npm run dev`, never in the .exe).
DEV_SKIP_AUTH=false
