# =========================================================
# Meetly — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# =========================================================

# ---- Deepgram (streaming transcription) ----
DEEPGRAM_API_KEY=

# ---- OpenAI (live assist + summaries + vision) ----
# Optional — users can also paste their own key in Settings (stored in OS keychain).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini

# ---- AWS region (all services in same region) ----
AWS_REGION=us-east-1

# ---- AWS Cognito (User Pool — created by Terraform) ----
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_IDENTITY_POOL_ID=

# ---- DynamoDB ----
DYNAMODB_TABLE=Meetly

# ---- Development ----
# Set true to bypass content-protection (so you can screenshot for design QA)
VITE_DEV_DISABLE_STEALTH=false
